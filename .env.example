# ============================================
# APPLICATION CONFIGURATION
# ============================================
NODE_ENV=development
# Options: development, production, test
PORT=3000

# ============================================
# DATABASE CONFIGURATION
# ============================================
DATABASE_URL=postgresql://postgres:password@localhost:5432/phlov_meas

# For production use:
# DATABASE_URL=postgresql://user:strong_password@db.example.com:5432/phlov_meas?ssl=true

# ============================================
# SECURITY SECRETS (MUST BE CHANGED IN PRODUCTION!)
# ============================================
# Generate using: node scripts/generate-secrets.js
JWT_SECRET=change_this_to_random_64_char_string_in_production
JWT_REFRESH_SECRET=change_this_to_different_random_64_char_string_in_production
CSRF_SECRET=change_this_to_another_random_64_char_string_in_production

# Example of strong secrets (DO NOT use these in production):
# JWT_SECRET=a8f9e2c1d4b5a7e3f6c8d9e0f1a2b3c4d5e6f7a8b9c0d1e2f3a4b5c6d7e8f9a0

# ============================================
# FRONTEND URLs (for CORS)
# ============================================
FRONTEND_URL=http://localhost:3000
ADMIN_URL=http://localhost:3001

# For production:
# FRONTEND_URL=https://phlov-meas.edu.kh
# ADMIN_URL=https://admin.phlov-meas.edu.kh

# ============================================
# REDIS (optional - for production rate limiting)
# ============================================
# REDIS_URL=redis://localhost:6379
# For production with password:
# REDIS_URL=redis://:password@redis.example.com:6379

# ============================================
# EMAIL CONFIGURATION (for password reset, notifications)
# ============================================
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password
# EMAIL_FROM=noreply@phlov-meas.edu.kh

# ============================================
# LOGGING
# ============================================
LOG_LEVEL=info
# Options: debug, info, warn, error
LOG_FILE_PATH=./logs/app.log

# ============================================
# FILE UPLOAD (if applicable)
# ============================================
MAX_FILE_SIZE=5242880  # 5MB in bytes
UPLOAD_DIR=./uploads
ALLOWED_FILE_TYPES=image/jpeg,image/png,application/pdf

# ============================================
# RATE LIMITING
# ============================================
RATE_LIMIT_WINDOW_MS=900000  # 15 minutes
RATE_LIMIT_MAX_REQUESTS=100
AUTH_RATE_LIMIT_MAX=10

# ============================================
# SESSION CONFIGURATION
# ============================================
ACCESS_TOKEN_EXPIRY=15m
REFRESH_TOKEN_EXPIRY=7d
SESSION_COOKIE_MAX_AGE=86400000  # 24 hours in ms

# ============================================
# SECURITY FEATURES TOGGLE
# ============================================
ENABLE_CSRF=true
ENABLE_RATE_LIMITING=true
ENABLE_2FA=false  # Set to true when implementing 2FA
ENABLE_SSL_REDIRECT=true  # Auto-redirect HTTP to HTTPS

# ============================================
# MONITORING & ALERTS (optional)
# ============================================
# SENTRY_DSN=https://your-dsn@sentry.io/project-id
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/yyy/zzz
